{
  "name": "arc6ai_info_extraction",
  "version": "1.0.0",
  "description": "Info Extraction skill — extract content from any file (text or scanned) as clean Markdown",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "start": "node --import tsx/esm src/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13",
    "fflate": "^0.8.2",
    "hono": "^4.12.9",
    "mammoth": "^1.8",
    "openai": "^4.73",
    "unpdf": "^1.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "dotenv": "^16",
    "tsx": "^4.19",
    "typescript": "^5.7",
    "wrangler": "^4.77.0"
  }
}
